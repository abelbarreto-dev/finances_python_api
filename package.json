{
  "name": "finances_python_api",
  "version": "1.0.0",
  "description": "finances api using python",
  "main": "app.py",
  "repository": "git@github.com:abelbarreto-dev/finances_python_api.git",
  "author": "Abel Carvalho <abelbcarvalho.dev@gmail.com>",
  "license": "MIT",
  "scripts": {
    "migrate:base": "alembic downgrade base",
    "migrate:gen": "alembic revision --autogenerate -m ",
    "migrate:run": "alembic upgrade head",
    "migrate:revert": "alembic downgrade -1",
    "migrate:info": "alembic current",
    "format:imports": "ruff check --select I --fix . && sdsort .",
    "format:files": "ruff format .",
    "graphql:gen": "python gen.graphql.py && yarn format:imports && yarn format:files"
  }
}